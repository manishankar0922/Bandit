{
  "manifest_version": 3,
  "name": "Bandit — AI Prompt Companion",
  "version": "2.0",
  "description": "A pixel-art raccoon that lives on every page — enhances your prompts, summarizes AI chats, and levels up as you use it.",
  "browser_specific_settings": {
    "gecko": {
      "id": "rocky@vibecoding.pet",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "permissions": ["storage", "contextMenus", "clipboardWrite"],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*"
  ],
  "background": {
    "scripts": ["storage.js", "ai/providers.js", "background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["storage.js", "ai/prompts.js", "ai/pipeline.js", "script.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["index.html", "styles.css", "script.js", "storage.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
